{
  "name": "telescope",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/desktop",
    "packages/ui"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "./scripts/pnpm.sh -r --if-present lint",
    "test": "./scripts/pnpm.sh -r --if-present test",
    "e2e": "./scripts/pnpm.sh -C apps/web e2e",
    "desktop:build": "./scripts/pnpm.sh -C apps/desktop build",
    "desktop:bundle": "./scripts/pnpm.sh -C apps/desktop bundle"
  },
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2",
      "esbuild": "0.25.12"
    }
  }
}
